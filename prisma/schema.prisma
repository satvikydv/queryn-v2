// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ---------------------------------------------------------------------------
// User
// ---------------------------------------------------------------------------

model User {
  id        String  @id @default(cuid())
  firstName String?
  lastName  String?
  imageUrl  String?
  email     String  @unique
  credits   Int     @default(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teamMemberships      TeamMember[]
  qaInteractions       QAInteraction[]
  razorpayTransactions RazorpayTransactions[]
}

// ---------------------------------------------------------------------------
// Project
// ---------------------------------------------------------------------------

enum IndexingStatus {
  IDLE
  PENDING
  IN_PROGRESS
  COMPLETED
  ERROR
}

model Project {
  id        String    @id @default(cuid())
  name      String
  githubUrl String
  deletedAt DateTime?

  // Indexing progress (DB-backed, serverless-safe) [Phase 5]
  indexingStatus IndexingStatus @default(IDLE)
  indexingMeta   Json?          // { processed, total, currentFile, phase, error }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teamMembers     TeamMember[]
  commits         Commit[]
  fileIndexes     FileIndex[]
  qaInteractions  QAInteraction[]
  meetingSessions MeetingSession[]
}

// ---------------------------------------------------------------------------
// TeamMember (renamed from UserToProject — DB table name preserved)
// ---------------------------------------------------------------------------

model TeamMember {
  id        String @id @default(cuid())
  userId    String
  projectId String
  role      String @default("MEMBER")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId])
  @@map("UserToProject")
}

// ---------------------------------------------------------------------------
// Commit
// ---------------------------------------------------------------------------

model Commit {
  id        String @id @default(cuid())
  projectId String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  commitMessage      String
  commitHash         String   @unique
  commitAuthorName   String
  commitAuthorAvatar String
  commitDate         DateTime
  summary            String

  project Project @relation(fields: [projectId], references: [id])
}

// ---------------------------------------------------------------------------
// FileIndex (renamed from SourceCodeEmbedding — DB table name preserved)
// Vector dimension: 3072 (Gemini) → 1024 (Amazon Bedrock Titan v2) [P12]
// Added sha for incremental re-indexing                           [P15]
// Added @@unique([projectId, fileName]) for upsert on re-index   [P15]
// ---------------------------------------------------------------------------

model FileIndex {
  id        String @id @default(cuid())
  projectId String

  fileName   String
  sourceCode String
  summary    String

  // Amazon Bedrock Titan Embed v2 — 1024 dimensions (P12, P13)
  embedding Unsupported("vector(1024)")?

  // File SHA for incremental indexing (P15) — null until first Bedrock index
  sha String?

  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, fileName])
  @@map("SourceCodeEmbedding")
}

// ---------------------------------------------------------------------------
// QAInteraction (renamed from Question — DB table + column names preserved)
// ---------------------------------------------------------------------------

model QAInteraction {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  question String
  answer   String?

  // DB column stays "filesReferences" for backward compatibility
  context Json? @map("filesReferences")

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  userId String
  user   User @relation(fields: [userId], references: [id])

  @@map("Question")
}

// ---------------------------------------------------------------------------
// MeetingSession (new — Amazon Transcribe + Bedrock + Amazon Q)  [Req 9]
// ---------------------------------------------------------------------------

enum MeetingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  FAILED
}

model MeetingSession {
  id           String        @id @default(cuid())
  projectId    String
  title        String?       // user-provided meeting title
  meetingUrl   String
  status       MeetingStatus @default(SCHEDULED)
  transcript   String?
  summary      Json?         // { summary, actionItems, decisions, keyPoints }
  duration     Int?          // seconds
  botSessionId String?       // internal bot runner key for stop/status lookup
  createdAt    DateTime      @default(now())
  endedAt      DateTime?

  project Project @relation(fields: [projectId], references: [id])

  @@map("meeting_sessions")
}

// ---------------------------------------------------------------------------
// RazorpayTransactions (unchanged)
// ---------------------------------------------------------------------------

model RazorpayTransactions {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  credits   Int
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}